{
  "name": "lookin-mcp-peertalk",
  "version": "0.1.0",
  "description": "MCP server for Lookin iOS view debugger using Peertalk protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bplist-parser": "^0.3.2",
    "bplist-creator": "^0.1.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "esbuild": "^0.20.0",
    "@types/node": "^20.0.0"
  }
}
